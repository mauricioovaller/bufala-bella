# Configuración de Entorno - Bufala Bella

# Base de Datos
VITE_API_BASE_URL=https://portal.datenbankensoluciones.com.co/DatenBankenApp/DiBufala/Api

# Base de Datos Local (para testing local)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=DiBufala
DB_PORT=3306

# Configuración de Correos
SMTP_HOST=smtp.tuproveedor.com
SMTP_PORT=587
SMTP_USER=tu-email@ejemplo.com
SMTP_PASSWORD=tu-contraseña
SMTP_FROM=noreply@bufalabell.com

# Configuración de Aplicación
NODE_ENV=development
VITE_APP_NAME=Bufala Bella
VITE_APP_VERSION=1.0.0

# Configuración de Seguridad
VITE_API_TIMEOUT=30000
VITE_MAX_UPLOAD_SIZE=5242880  # 5MB en bytes

# Configuración de Logging
VITE_LOG_LEVEL=debug  # debug, info, warn, error

# URLs Públicas
VITE_PUBLIC_URL=http://localhost:5173

# Modo Debug
VITE_DEBUG=true

# Configuración por Módulos
# Facturación
VITE_FACTURACION_ENABLED=true
VITE_FEX_ENABLED=true

# Pedidos
VITE_PEDIDOS_ENABLED=true

# Consolidación
VITE_CONSOLIDACION_ENABLED=true

# Sistema de Correos
VITE_CORREOS_ENABLED=true
VITE_CORREOS_HISTORIAL_ENABLED=true
VITE_CORREOS_PLANTILLAS_ENABLED=true

# Dashboard
VITE_DASHBOARD_ENABLED=true
VITE_DASHBOARD_REFRESH_INTERVAL=30000  # ms